# Copy to .env and fill in. (.env is gitignored; never commit real secrets.)

# ---- Database (required) ----
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ---- Session / auth ----
SESSION_SECRET=              # random hex; signs the OIDC state cookie
AUTH_DISABLED=               # set to 1 to bypass auth (local dev only)

# ---- Microsoft Entra ID (OIDC login) ----
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# ---- TV displays ----
TV_ALLOWED_IPS=              # comma-separated IPs allowed to view /tv/* without login

# ---- Zira.us API ----
ZIRA_API_KEY=
ZIRA_BASE_URL=https://api.zira.us/public/

# ---- Forklift (gpiforklift.com) ----
# Read-only integration: forklift call-queue demand + driver performance.
# NOTE: the forklift API currently serves reads without auth; the key is sent
# as a header anyway for forward-compatibility.
FORKLIFT_API_KEY=
FORKLIFT_BASE_URL=https://www.gpiforklift.com

# ---- Odoo (HR / attendance / time-off) ----
ODOO_URL=
ODOO_DB=
ODOO_LOGIN=
ODOO_API_KEY=
ODOO_KIOSK_WC_FIELD=         # optional: hr.attendance field carrying work center
ODOO_KIOSK_DEPARTMENT_FIELD= # optional: hr.attendance field carrying department

# ---- Slack (schedule share) ----
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ---- Kiosk / timeclock ----
KIOSK_SESSION_SECRET=        # HMAC secret for kiosk tokens; auto-generated if unset
KIOSK_TIME_OFF_ENABLED=      # set to 1 to enable kiosk time-off requests

# ---- Admin ----
ZIRA_ADMIN_SECRET=           # gates /admin maintenance endpoints

# ---- Server (optional) ----
HOST=0.0.0.0
PORT=8000
