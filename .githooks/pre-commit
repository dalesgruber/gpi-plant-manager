#!/bin/sh
# Shared pre-commit hook: auto-fix ruff lint on staged Python files so unlinted
# commits don't keep turning CI red. Non-blocking — fixes what it safely can,
# re-stages, and never fails the commit.
#
# Activate once per clone:   git config core.hooksPath .githooks
files=$(git diff --cached --name-only --diff-filter=ACM -- '*.py')
[ -z "$files" ] && exit 0

if [ -x ".venv/bin/ruff" ]; then RUFF=".venv/bin/ruff"
elif command -v ruff >/dev/null 2>&1; then RUFF="ruff"
elif [ -x ".venv/bin/python" ]; then RUFF=".venv/bin/python -m ruff"
else exit 0; fi

# shellcheck disable=SC2086
$RUFF check --fix --quiet $files >/dev/null 2>&1
# shellcheck disable=SC2086
git add $files >/dev/null 2>&1
exit 0
